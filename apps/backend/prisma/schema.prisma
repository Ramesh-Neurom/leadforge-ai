generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  name              String
  passwordHash      String
  role              Role          @default(BD_EXECUTIVE)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  assignedLeads     Lead[]        @relation("LeadAssignee")
  approvedProposals Proposal[]    @relation("ProposalApprover")
  crmActivities     CrmActivity[]
}

model LeadSource {
  id              String    @id @default(cuid())
  name            String
  type            String
  integrationType String
  status          String    @default("ACTIVE")
  configJson      Json?
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  lastSyncMessage String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  leads           Lead[]
}

model Lead {
  id               String         @id @default(cuid())
  sourceId         String
  sourceName       String
  externalId       String?
  title            String
  description      String
  clientName       String?
  clientCountry    String?
  clientEmail      String?
  clientProfileUrl String?
  projectUrl       String?
  budgetType       String?
  budgetMin        Float?
  budgetMax        Float?
  currency         String?
  skillsJson       Json?
  postedAt         DateTime?
  opportunityType  String?
  filterReason     String?
  filterScore      Int?
  status           LeadStatus     @default(NEW)
  assignedToId     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  source           LeadSource     @relation(fields: [sourceId], references: [id])
  assignedTo       User?          @relation("LeadAssignee", fields: [assignedToId], references: [id])
  analysis         LeadAnalysis?
  proposals        Proposal[]
  crmActivities    CrmActivity[]
  conversations    Conversation[]
  followups        Followup[]
  quotations       Quotation[]
  invoices         Invoice[]

  @@index([sourceId])
  @@index([status])
  @@index([postedAt])
  @@index([assignedToId])
}

model LeadAnalysis {
  id                 String   @id @default(cuid())
  leadId             String   @unique
  leadScore          Int
  priority           String
  category           String?
  requiredSkillsJson Json?
  budgetQuality      String?
  clientSeriousness  String?
  redFlagsJson       Json?
  aiSummary          String?
  recommendedAction  String?
  createdAt          DateTime @default(now())
  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Proposal {
  id                 String         @id @default(cuid())
  leadId             String
  proposalText       String
  solutionSummary    String?
  timeline           String?
  budgetRange        String?
  questionsJson      Json?
  portfolioLinksJson Json?
  status             ProposalStatus @default(DRAFT)
  approvedById       String?
  approvedAt         DateTime?
  sentMethod         String?
  sentAt             DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  lead               Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  approvedBy         User?          @relation("ProposalApprover", fields: [approvedById], references: [id])
  quotations         Quotation[]

  @@index([leadId])
  @@index([status])
  @@index([approvedById])
}

model CrmActivity {
  id           String   @id @default(cuid())
  leadId       String
  userId       String
  activityType String
  description  String
  metadataJson Json?
  createdAt    DateTime @default(now())
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
}

model Conversation {
  id            String    @id @default(cuid())
  leadId        String
  clientName    String?
  source        String
  status        String    @default("OPEN")
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([leadId])
  @@index([status])
  @@index([lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderType     SenderType
  messageText    String
  messageChannel String
  aiSummary      String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderType])
  @@index([createdAt])
}

model Followup {
  id           String         @id @default(cuid())
  leadId       String
  followupType String
  message      String
  scheduledAt  DateTime
  status       FollowupStatus @default(PENDING)
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, followupType])
  @@index([leadId])
  @@index([status])
  @@index([scheduledAt])
}

model Quotation {
  id           String          @id @default(cuid())
  leadId       String
  proposalId   String?
  scopeSummary String
  amount       Float
  currency     String
  timeline     String?
  paymentTerms String?
  status       QuotationStatus @default(DRAFT)
  pdfUrl       String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lead         Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  proposal     Proposal?       @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([proposalId])
  @@index([status])
}

model Invoice {
  id            String               @id @default(cuid())
  leadId        String
  clientName    String?
  amount        Float
  currency      String
  invoiceNumber String               @unique
  invoicePdfUrl String?
  paymentStatus InvoicePaymentStatus @default(UNPAID)
  dueDate       DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  lead          Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([paymentStatus])
  @@index([dueDate])
}

enum Role {
  ADMIN
  MANAGER
  BD_EXECUTIVE
  FINANCE
  TECH_REVIEWER
}

enum LeadStatus {
  NEW
  AI_REVIEWED
  QUALIFIED
  PROPOSAL_DRAFTED
  WAITING_APPROVAL
  PROPOSAL_SENT
  CLIENT_REPLIED
  FOLLOW_UP_NEEDED
  MEETING_SCHEDULED
  NEGOTIATION
  WON
  LOST
  REJECTED
}

enum ProposalStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  REJECTED
  SENT
}

enum SenderType {
  CLIENT
  MANAGER
  AI_DRAFT
  SYSTEM
}

enum FollowupStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum InvoicePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}
